---
import { getOwnerLabel } from "@/lib/labels";

interface WorkflowStep {
  step: string;
  input: string;
  process: string;
  output: string;
  owner: "ai" | "human" | "system";
}

interface Props {
  steps: WorkflowStep[];
  title?: string;
}

const { steps, title = "AI Workflow / Agent 设计" } = Astro.props;
---

<section class="surface-card p-6">
  <p class="eyebrow">工作流</p>
  <h2 class="mt-3 text-2xl font-semibold">{title}</h2>
  <div class="mt-6 grid gap-4 md:grid-cols-3">
    {steps.map((step) => (
      <div class="border border-[var(--color-border-subtle)] p-4">
        <p class="font-semibold">{step.step}</p>
        <p class="mt-3 text-sm text-[var(--color-text-secondary)]">输入：{step.input}</p>
        <p class="mt-2 text-sm text-[var(--color-text-secondary)]">处理：{step.process}</p>
        <p class="mt-2 text-sm text-[var(--color-text-secondary)]">输出：{step.output}</p>
        <p class="mt-3 font-mono text-xs text-[var(--color-accent)]">{getOwnerLabel(step.owner)}</p>
      </div>
    ))}
  </div>
</section>
