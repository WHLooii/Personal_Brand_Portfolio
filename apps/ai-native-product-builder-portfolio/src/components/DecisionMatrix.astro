---
interface Boundary {
  task: string;
  ai_can_do: string;
  human_must_do: string;
}

interface Props {
  boundaries: Boundary[];
}

const { boundaries } = Astro.props;
---

<section class="surface-card p-6">
  <p class="eyebrow">产品判断</p>
  <h2 class="mt-3 text-2xl font-semibold">AI Boundary</h2>
  <div class="mt-6 space-y-3">
    {boundaries.map((boundary) => (
      <article class="border border-[var(--color-border-subtle)] p-4">
        <h3 class="font-semibold leading-snug">{boundary.task}</h3>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <div>
            <p class="font-mono text-xs text-[var(--color-accent)]">AI 可以做</p>
            <p class="mt-2 text-sm leading-6 text-[var(--color-text-secondary)]">{boundary.ai_can_do}</p>
          </div>
          <div>
            <p class="font-mono text-xs text-[var(--color-accent)]">人必须负责</p>
            <p class="mt-2 text-sm leading-6 text-[var(--color-text-secondary)]">{boundary.human_must_do}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
