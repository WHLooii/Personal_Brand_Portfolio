---
const abilities = [
  {
    code: "01",
    className: "problem",
    title: "Problem",
    meta: "问题定义",
    detail: "从业务场景里拆出真实痛点、用户角色和可验证问题。"
  },
  {
    code: "02",
    className: "judgment",
    title: "Judgment",
    meta: "AI 判断",
    detail: "判断 AI 是否适合介入、边界在哪里、哪些决策必须由人完成。"
  },
  {
    code: "03",
    className: "workflow",
    title: "Workflow",
    meta: "人机协作",
    detail: "设计 Agent / Copilot 与 Human-in-the-loop 的协作链路。"
  },
  {
    code: "04",
    className: "prototype",
    title: "Prototype",
    meta: "MVP 原型",
    detail: "把判断落成可演示、可测试、可复盘的产品原型。"
  },
  {
    code: "05",
    className: "evaluation",
    title: "Evaluation",
    meta: "评估闭环",
    detail: "定义产品指标、AI 输出质量指标和下一轮迭代证据。"
  },
  {
    code: "06",
    className: "reflection",
    title: "Reflection",
    meta: "复盘迭代",
    detail: "复盘限制、风险、取舍和下一步验证路径。"
  }
];
---

<aside id="capability-system" class="hero-system" aria-label="AI Product Builder 能力可视化">
  <div class="hero-system__header">
    <div>
      <p>AI Product Capability Visualization</p>
      <h2>Product Operating System</h2>
    </div>
  </div>

  <div class="system-map" aria-label="AI Product Builder 中心辐射能力图">
    <svg class="system-lines" viewBox="0 0 640 420" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="hero-flow-line" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0%" stop-color="rgba(91, 140, 255, 0.18)" />
          <stop offset="50%" stop-color="rgba(164, 197, 255, 0.58)" />
          <stop offset="100%" stop-color="rgba(139, 92, 246, 0.2)" />
        </linearGradient>
        <linearGradient id="hero-flow-active" x1="0" x2="1">
          <stop offset="0%" stop-color="rgba(91, 140, 255, 0)" />
          <stop offset="48%" stop-color="rgba(191, 238, 255, 0.78)" />
          <stop offset="100%" stop-color="rgba(139, 92, 246, 0)" />
        </linearGradient>
        <radialGradient id="hero-center-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgba(126, 202, 255, 0.28)" />
          <stop offset="100%" stop-color="rgba(126, 202, 255, 0)" />
        </radialGradient>
      </defs>
      <path class="system-ring" d="M320 46 500 112 496 304 320 372 144 304 140 112Z" />
      <path class="system-flow system-flow--ring" d="M320 46 500 112 496 304 320 372 144 304 140 112 320 46" />
      <path class="system-spoke" d="M320 210 320 46M320 210 500 112M320 210 496 304M320 210 320 372M320 210 144 304M320 210 140 112" />
      <circle cx="320" cy="210" r="138" fill="url(#hero-center-glow)" />
    </svg>

    <div class="system-center">
      <span>Core</span>
      <strong>AI Product Builder</strong>
    </div>

    {abilities.map((ability) => (
      <article class={`system-node system-node--${ability.className}`} tabindex="0">
        <span class="system-node__code">{ability.code}</span>
        <h3>{ability.title}</h3>
        <p>{ability.meta}</p>
        <small>{ability.detail}</small>
      </article>
    ))}
  </div>
</aside>

<style>
  .hero-system {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(169, 196, 255, 0.14);
    border-radius: var(--radius-card);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
      var(--surface-glass-subtle);
    box-shadow:
      0 32px 90px rgba(0, 0, 0, 0.32),
      0 24px 72px rgba(91, 140, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    color: rgba(241, 247, 255, 0.94);
    backdrop-filter: blur(22px);
  }

  .hero-system::before {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, transparent, rgba(135, 188, 255, 0.09), transparent),
      radial-gradient(circle at 86% 16%, rgba(141, 187, 255, 0.18), transparent 34%),
      radial-gradient(circle at 62% 90%, rgba(142, 95, 255, 0.12), transparent 38%);
    pointer-events: none;
  }

  .hero-system::after {
    position: absolute;
    inset: 1px;
    border-radius: calc(var(--radius-card) - 1px);
    content: "";
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.045);
    pointer-events: none;
  }

  .hero-system__header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 22px 0;
  }

  .hero-system__header p,
  .hero-system__header h2 {
    margin: 0;
  }

  .hero-system__header p {
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .hero-system__header h2 {
    margin-top: 7px;
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .system-map {
    position: relative;
    z-index: 1;
    min-height: 420px;
    margin: 4px 8px 14px;
  }

  .system-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.92;
  }

  .system-ring,
  .system-spoke,
  .system-flow {
    fill: none;
    stroke-linecap: round;
    stroke-width: 1;
  }

  .system-ring,
  .system-spoke {
    stroke: url(#hero-flow-line);
  }

  .system-spoke {
    stroke-dasharray: 4 10;
  }

  .system-flow {
    stroke: url(#hero-flow-active);
    stroke-dasharray: 72 430;
    stroke-width: 1.4;
    animation: hero-flow 8s linear infinite;
  }

  .system-center,
  .system-node {
    position: absolute;
    z-index: 2;
    display: grid;
    place-items: center;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(176, 207, 255, 0.2);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.035);
    box-shadow:
      0 14px 34px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    text-align: center;
    backdrop-filter: blur(14px);
  }

  .system-center {
    top: 50%;
    left: 50%;
    width: 208px;
    min-height: 122px;
    padding: 18px;
    background:
      linear-gradient(140deg, rgba(21, 45, 77, 0.72), rgba(39, 33, 88, 0.62)),
      var(--surface-glass-subtle);
    box-shadow:
      0 0 46px rgba(99, 167, 255, 0.18),
      0 18px 42px rgba(0, 0, 0, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.09);
    animation: hero-breathe 5.8s ease-in-out infinite;
  }

  .system-center::before {
    position: absolute;
    inset: -40px;
    z-index: -1;
    border-radius: var(--radius-round);
    content: "";
    background:
      radial-gradient(circle, rgba(126, 202, 255, 0.24), transparent 58%),
      radial-gradient(circle, rgba(153, 111, 255, 0.18), transparent 66%);
    filter: blur(4px);
  }

  .system-center span {
    color: rgba(178, 214, 255, 0.68);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
  }

  .system-center strong {
    margin-top: 8px;
    font-size: 1.12rem;
    font-weight: 760;
    line-height: 1.2;
  }

  .system-node {
    width: 128px;
    min-height: 92px;
    padding: 13px 11px;
    transition:
      transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
      background 200ms cubic-bezier(0.2, 0.8, 0.2, 1);
    animation: hero-node-breathe 6.8s ease-in-out infinite;
  }

  .system-node:focus-visible {
    outline: 2px solid rgba(191, 238, 255, 0.9);
    outline-offset: 4px;
  }

  .system-node:hover,
  .system-node:focus-visible {
    z-index: 4;
    transform: translate(-50%, -53%);
    border-color: rgba(191, 238, 255, 0.46);
    background: rgba(15, 25, 54, 0.76);
  }

  .system-node__code {
    position: absolute;
    top: 8px;
    left: 9px;
    color: rgba(180, 218, 255, 0.48);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1;
  }

  .system-node h3,
  .system-node p,
  .system-node small {
    margin: 0;
  }

  .system-node h3 {
    margin-top: 9px;
    font-size: 0.98rem;
    font-weight: 740;
    line-height: 1.18;
  }

  .system-node p {
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .system-node small {
    overflow: hidden;
    max-height: 0;
    margin-top: 0;
    color: rgba(216, 229, 249, 0.76);
    font-size: 0.72rem;
    line-height: 1.55;
    opacity: 0;
    transition:
      max-height 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      margin-top 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      opacity 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .system-node:hover small,
  .system-node:focus-visible small {
    max-height: 90px;
    margin-top: 8px;
    opacity: 1;
  }

  .system-node--problem {
    top: 12%;
    left: 50%;
  }

  .system-node--judgment {
    top: 30%;
    left: 81%;
    animation-delay: 0.2s;
  }

  .system-node--workflow {
    top: 72%;
    left: 80%;
    animation-delay: 0.4s;
  }

  .system-node--prototype {
    top: 86%;
    left: 50%;
    animation-delay: 0.6s;
  }

  .system-node--evaluation {
    top: 72%;
    left: 20%;
    animation-delay: 0.8s;
  }

  .system-node--reflection {
    top: 30%;
    left: 19%;
    animation-delay: 1s;
  }

  @keyframes hero-flow {
    to {
      stroke-dashoffset: -502;
    }
  }

  @keyframes hero-breathe {
    0%,
    100% {
      box-shadow:
        0 0 42px rgba(99, 167, 255, 0.16),
        0 18px 42px rgba(0, 0, 0, 0.26),
        inset 0 1px 0 rgba(255, 255, 255, 0.09);
    }

    50% {
      box-shadow:
        0 0 62px rgba(99, 167, 255, 0.24),
        0 20px 48px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }
  }

  @keyframes hero-node-breathe {
    0%,
    100% {
      border-color: rgba(176, 207, 255, 0.18);
    }

    50% {
      border-color: rgba(176, 207, 255, 0.3);
    }
  }

  @supports not (backdrop-filter: blur(1px)) {
    .hero-system,
    .system-center,
    .system-node {
      background: rgba(7, 12, 26, 0.92);
    }
  }

  @media (max-width: 560px) {
    .hero-system__header {
      padding: 18px 18px 0;
    }

    .system-map {
      display: grid;
      gap: 10px;
      min-height: auto;
      margin: 18px;
    }

    .system-lines {
      display: none;
    }

    .system-center,
    .system-node {
      position: static;
      width: 100%;
      min-height: 0;
      transform: none;
      padding: 13px;
    }

    .system-node:hover,
    .system-node:focus-visible {
      transform: none;
    }

    .system-node h3 {
      margin-top: 13px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .system-center,
    .system-node,
    .system-flow {
      animation: none;
    }

    .system-node,
    .system-node small {
      transition: none;
    }
  }
</style>
