---
interface Props {
  items: string[];
  title?: string;
}

const { items, title = "时间线" } = Astro.props;
---

<section class="surface-card p-6">
  <p class="eyebrow">迭代</p>
  <h2 class="mt-3 text-2xl font-semibold">{title}</h2>
  <ol class="mt-6 space-y-3">
    {items.map((item, index) => (
      <li class="flex gap-3 text-sm leading-6 text-[var(--color-text-secondary)]">
        <span class="font-mono text-xs text-[var(--color-accent)]">{String(index + 1).padStart(2, "0")}</span>
        <span>{item}</span>
      </li>
    ))}
  </ol>
</section>
