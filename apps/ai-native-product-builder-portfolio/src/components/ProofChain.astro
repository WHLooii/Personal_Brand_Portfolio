---
const nodes = [
  {
    icon: "target",
    title: "真实业务场景",
    detail: "用户、角色、痛点、业务代价"
  },
  {
    icon: "workflow",
    title: "Workflow 拆解",
    detail: "输入、步骤、决策点、异常"
  },
  {
    icon: "sliders",
    title: "AI 介入判断",
    detail: "Copilot / Agent / RAG / Workflow layer"
  },
  {
    icon: "shield",
    title: "Human Boundary",
    detail: "人审、责任、风险兜底"
  },
  {
    icon: "route",
    title: "系统设计",
    detail: "工具调用、检索、记忆、失败恢复"
  },
  {
    icon: "blocks",
    title: "原型执行",
    detail: "页面、交互、样例数据、演示闭环"
  },
  {
    icon: "gauge",
    title: "Eval / ROI / Proof",
    detail: "指标、成本、质量、复盘证据"
  }
];

const icons: Record<string, string> = {
  target:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8"></circle><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M2 12h3M19 12h3"></path></svg>',
  workflow:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6h6v6H6zM14 14h4v4h-4z"></path><path d="M12 9h3a3 3 0 0 1 3 3v2M9 12v3a3 3 0 0 0 3 3h2"></path></svg>',
  sliders:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h7M15 7h5M4 17h5M13 17h7"></path><circle cx="13" cy="7" r="2"></circle><circle cx="11" cy="17" r="2"></circle></svg>',
  shield:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 19 6v6c0 4.5-2.9 7.4-7 9-4.1-1.6-7-4.5-7-9V6z"></path><path d="m9 12 2 2 4-5"></path></svg>',
  route:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="6" cy="6" r="2"></circle><circle cx="18" cy="18" r="2"></circle><path d="M8 6h4a4 4 0 0 1 0 8h-1a4 4 0 0 0 0 8h7"></path></svg>',
  blocks:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5h6v6H5zM13 5h6v6h-6zM5 13h6v6H5zM13 13h6v6h-6z"></path></svg>',
  gauge:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 14a8 8 0 0 1 16 0"></path><path d="M12 14 16 9"></path><path d="M7 14h10"></path><path d="M6 18h12"></path></svg>'
};
---

<aside class="proof-chain" aria-label="巫浩林的 AI 产品能力证明链条">
  <div class="proof-chain__header">
    <span>Problem</span>
    <span>Workflow</span>
    <span>Prototype</span>
    <span>Proof</span>
  </div>
  <ol class="proof-chain__list">
    {nodes.map((node) => (
      <li class="proof-chain__item">
        <div class="proof-chain__icon" set:html={icons[node.icon]} />
        <div>
          <h2>{node.title}</h2>
          <p>{node.detail}</p>
        </div>
      </li>
    ))}
  </ol>
</aside>

<style>
  .proof-chain {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background:
      linear-gradient(90deg, rgba(10, 10, 10, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, rgba(10, 10, 10, 0.035) 1px, transparent 1px),
      var(--color-surface);
    background-size: 40px 40px;
    padding: 22px;
    box-shadow: 0 28px 80px rgba(10, 10, 10, 0.08);
  }

  .proof-chain::before {
    position: absolute;
    inset: 72px auto 34px 43px;
    width: 1px;
    content: "";
    background: linear-gradient(180deg, var(--color-accent-border), var(--color-border-subtle));
  }

  .proof-chain::after {
    position: absolute;
    top: 72px;
    left: 42px;
    width: 3px;
    height: 72px;
    border-radius: 999px;
    content: "";
    background: var(--color-accent);
    opacity: 0.42;
    animation: connector-flow 5.8s ease-in-out infinite;
  }

  .proof-chain__header {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-bottom: 18px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .proof-chain__header span {
    border: 1px solid var(--color-border-subtle);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    padding: 6px 8px;
    text-align: center;
  }

  .proof-chain__list {
    position: relative;
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .proof-chain__item {
    position: relative;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 14px;
    align-items: center;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.94);
    padding: 13px;
    transition:
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .proof-chain__item:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent-border);
  }

  .proof-chain__icon {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-card);
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .proof-chain__icon :global(svg) {
    width: 21px;
    height: 21px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .proof-chain__item h2 {
    margin: 0;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .proof-chain__item p {
    margin: 6px 0 0;
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  @keyframes connector-flow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(318px);
    }
  }

  @media (max-width: 980px) {
    .proof-chain {
      box-shadow: none;
    }
  }

  @media (max-width: 560px) {
    .proof-chain {
      padding: 16px;
    }

    .proof-chain::before {
      left: 35px;
    }

    .proof-chain::after {
      left: 34px;
    }

    .proof-chain__header {
      grid-template-columns: repeat(2, 1fr);
    }

    .proof-chain__item {
      grid-template-columns: 38px 1fr;
      padding: 12px;
    }

    .proof-chain__icon {
      width: 38px;
      height: 38px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .proof-chain::after,
    .proof-chain__item {
      animation: none;
      transition: none;
    }

    .proof-chain__item:hover {
      transform: none;
    }
  }
</style>
