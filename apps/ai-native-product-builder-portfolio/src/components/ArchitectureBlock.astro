---
interface Props {
  architecture: string;
  dataFlow: string;
}

const { architecture, dataFlow } = Astro.props;
---

<section class="surface-card p-6">
  <p class="eyebrow">系统架构</p>
  <h2 class="mt-3 text-2xl font-semibold">系统形态</h2>
  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <div class="border border-[var(--color-border-subtle)] p-4">
      <h3 class="font-semibold">架构</h3>
      <p class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">{architecture}</p>
    </div>
    <div class="border border-[var(--color-border-subtle)] p-4">
      <h3 class="font-semibold">数据流</h3>
      <p class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">{dataFlow}</p>
    </div>
  </div>
</section>
