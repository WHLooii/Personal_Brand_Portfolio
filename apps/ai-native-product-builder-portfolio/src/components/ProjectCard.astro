---
import { getProjectSlug, type ProjectEntry } from "@/lib/content";
import { getCapabilityLabel, getStatusLabel } from "@/lib/labels";

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const data = project.data;
const slug = getProjectSlug(project);
---

<article class="project-card" aria-labelledby={`project-${slug}-title`}>
  <div class="project-card__topline">
    <p class="eyebrow">{getCapabilityLabel(data.brand_evidence.primary_capability)}</p>
    <span class="project-card__status">{getStatusLabel(data.basic.status)}</span>
  </div>

  <h3 id={`project-${slug}-title`}>{data.basic.title}</h3>
  <p class="project-card__tagline">{data.basic.tagline}</p>

  <dl class="project-card__facts">
    <div>
      <dt>问题</dt>
      <dd>{data.context.problem}</dd>
    </div>
    <div>
      <dt>AI 角色</dt>
      <dd>{data.ai_design.ai_role}</dd>
    </div>
    <div>
      <dt>我的角色</dt>
      <dd>{data.basic.role}</dd>
    </div>
  </dl>

  <a class="project-card__link" href={`/projects/${slug}/`}>
    <span>查看案例</span>
    <span class="project-card__link-arrow" aria-hidden="true">↗</span>
  </a>
</article>

<style>
  .project-card {
    display: flex;
    min-width: 0;
    height: 100%;
    flex-direction: column;
    border: 1px solid var(--color-border-cool-subtle);
    border-radius: var(--radius-card);
    padding: clamp(28px, 2.7vw, 32px);
    background: var(--surface-paper-translucent);
    box-shadow: var(--shadow-paper-card);
    transition:
      transform var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard);
  }

  .project-card:hover,
  .project-card:focus-within {
    transform: translateY(-4px);
    border-color: var(--color-accent-border);
    box-shadow: 0 22px 54px rgba(20, 28, 45, 0.09);
  }

  .project-card__topline {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
  }

  .project-card__topline .eyebrow {
    margin: 5px 0 0;
  }

  .project-card__status {
    flex: 0 0 auto;
    border: 1px solid var(--color-border-cool-subtle);
    border-radius: var(--radius-round);
    padding: 5px 10px;
    background: var(--color-porcelain-raised);
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 620;
    line-height: 1.4;
  }

  .project-card h3 {
    margin: 24px 0 0;
    color: var(--color-text-primary-cool);
    font-size: 1.5rem;
    font-weight: 720;
    line-height: 1.25;
  }

  .project-card__tagline {
    margin: 12px 0 0;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .project-card__facts {
    display: grid;
    gap: 0;
    margin: 28px 0 0;
    border-top: 1px solid var(--color-border-cool-subtle);
  }

  .project-card__facts div {
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr);
    gap: 14px;
    padding-block: 16px;
    border-bottom: 1px solid var(--color-border-cool-subtle);
  }

  .project-card__facts dt {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 650;
    line-height: 1.65;
  }

  .project-card__facts dd {
    margin: 0;
    color: var(--color-text-primary-cool);
    font-size: 0.84rem;
    line-height: 1.7;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: auto;
    padding-top: 24px;
    color: var(--color-accent);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .project-card__link-arrow {
    transition: transform var(--duration-fast) var(--ease-standard);
  }

  .project-card__link:hover .project-card__link-arrow {
    transform: translate(3px, -3px);
  }

  @media (max-width: 520px) {
    .project-card {
      padding: 24px 22px;
    }

    .project-card__topline {
      gap: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__link-arrow {
      transition: none;
    }

    .project-card:hover,
    .project-card:focus-within,
    .project-card__link:hover .project-card__link-arrow {
      transform: none;
    }
  }
</style>
