---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CapabilityMap from "@/components/CapabilityMap.astro";
import HeroAbilitySystem from "@/components/HeroAbilitySystem.astro";
import WorkflowDiagram from "@/components/WorkflowDiagram.astro";
import { getProjectSlug, getProjects } from "@/lib/content";

const projects = await getProjects();
const methodSampleProject = projects.find((project) => getProjectSlug(project) === "ecommerce-review-copilot");
const methodSampleHref = methodSampleProject
  ? `/projects/${getProjectSlug(methodSampleProject)}/`
  : "/projects/ecommerce-review-copilot/";

const methodWorkflow = ["评论输入", "主题聚类", "差评归因", "风险提示", "建议卡片", "人工复盘", "指标评估"];

const methodCapabilities = [
  "能从模糊业务需求中拆出真实问题",
  "能判断 AI 适合做什么、不适合做什么",
  "能设计 Human-in-the-loop 的人机协作闭环",
  "能把产品判断落成可演示、可测试的 MVP",
  "能为 AI 输出设计评估指标，而不是只停留在“看起来能用”"
];

const shellWorkflow: Array<{
  step: string;
  input: string;
  process: string;
  output: string;
  owner: "ai" | "human" | "system";
}> = [
  {
    step: "业务问题",
    input: "用户场景与业务代价",
    process: "识别真实痛点、用户角色和当前替代方案",
    output: "待验证问题",
    owner: "human"
  },
  {
    step: "AI 判断",
    input: "待验证问题",
    process: "判断 AI 介入点、边界和不该自动化的部分",
    output: "AI 适配边界",
    owner: "human"
  },
  {
    step: "Workflow",
    input: "AI 适配边界",
    process: "设计 Agent/RAG/Copilot 与 Human-in-the-loop 链路",
    output: "可控工作流",
    owner: "system"
  },
  {
    step: "原型执行",
    input: "可控工作流",
    process: "落成页面、交互、样例数据和演示闭环",
    output: "可运行原型",
    owner: "system"
  },
  {
    step: "评估复盘",
    input: "可运行原型",
    process: "检查产品指标、AI 指标、风险和成本",
    output: "可复现证据",
    owner: "human"
  }
];
---

<BaseLayout headerVariant="dark">
  <section class="hero-section">
    <div class="site-shell hero-grid">
      <div class="hero-copy">
        <div class="hero-identity" aria-label="巫浩林个人品牌签名">
          <p class="hero-name">巫浩林</p>
          <p class="hero-role">AI 产品原型构建者 / Personal Portfolio</p>
        </div>
        <h1 class="hero-title">
          <span>把业务问题拆成</span>
          <span>可验证的</span>
          <span class="hero-keyword">AI 产品原型</span>
        </h1>
        <p class="hero-subtitle">
          用产品思维、系统拆解与 AI 工具链，把模糊需求转化为可演示、可测试、可迭代的解决方案。
        </p>
        <div class="hero-actions" aria-label="首页主要操作">
          <a class="hero-cta hero-cta-primary" href="/projects/">查看作品集</a>
          <a class="hero-cta hero-cta-secondary" href="#capabilities">了解能力模型</a>
        </div>
      </div>
      <HeroAbilitySystem />
    </div>
  </section>

  <section class="method-sample-section section">
    <div class="site-shell">
      <div class="method-sample-heading">
        <p class="eyebrow">能力样本</p>
        <h2>方法样本：我如何拆解一个 AI 产品机会</h2>
        <p>
          当前我先公开一个完整的 AIPM 判断链路样本。完整项目案例会在截图、指标和复盘补齐后逐步上线。这里重点展示的不是项目数量，而是我如何判断一个 AI 产品机会是否值得做、应该怎么做、以及如何验证它。
        </p>
      </div>

      <article class="method-sample-card">
        <div class="method-sample-card__main">
          <p class="method-sample-stage">
            当前验证阶段：V0.1 方法样本，重点验证产品判断链路、交互闭环与评估方法。
          </p>
          <h3>样本 01：从非结构化评论到运营决策 Copilot</h3>

          <div class="method-sample-blocks">
            <div class="method-sample-block">
              <p class="method-sample-label">问题</p>
              <p>
                评论数据量大、表达口语化、归因不稳定，运营团队难以从大量用户评论中快速判断问题优先级。
              </p>
            </div>
            <div class="method-sample-block">
              <p class="method-sample-label">我的判断</p>
              <p>
                这个场景不适合一开始就做“自动运营 Agent”。更合理的切入点是先做一个可复核的评论洞察 Copilot，让 AI 帮助运营人员完成主题聚类、差评归因、风险提示和建议生成，但最终决策仍由人确认。
              </p>
            </div>
            <div class="method-sample-block">
              <p class="method-sample-label">原型方向</p>
              <p>
                先把评论洞察流程落成可演示、可复核的 MVP，让每一步输出都能被人工确认，并能进入后续指标评估。
              </p>
              <div class="method-workflow" aria-label="评论洞察 Copilot 原型方向">
                {
                  methodWorkflow.map((step, index) => (
                    <span class="method-workflow__step">
                      <span class="method-workflow__index">{String(index + 1).padStart(2, "0")}</span>
                      <span>{step}</span>
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <aside class="method-sample-proof" aria-label="样本能力证明">
          <p class="eyebrow">能力证明</p>
          <h4>这个样本证明什么能力</h4>
          <ul>
            {methodCapabilities.map((capability) => <li>{capability}</li>)}
          </ul>
          <a class="method-sample-link" href={methodSampleHref}>查看拆解过程</a>
        </aside>
      </article>
    </div>
  </section>

  <section id="process" class="site-shell section">
    <WorkflowDiagram steps={shellWorkflow} title="产品构建流程" />
  </section>

  <section id="capabilities" class="site-shell section">
    <CapabilityMap />
  </section>

  <section id="contact" class="site-shell section">
    <div class="surface-card p-8">
      <p class="eyebrow">进一步沟通</p>
      <h2 class="mt-3 text-3xl font-semibold">如果你想评估我的 AI 产品构建能力，可以先从案例里的判断链路开始。</h2>
      <p class="mt-4 max-w-2xl text-[var(--color-text-secondary)]">
        当前作品集优先展示我如何定义问题、设计 AI 介入点、保留人类边界并验证输出质量；更完整的案例、原型证据和评测记录会继续按增量补齐。
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: calc(100svh - 77px);
    display: grid;
    align-items: center;
    padding-block: 88px 96px;
    background:
      radial-gradient(circle at 78% 34%, rgba(82, 124, 255, 0.18), transparent 28%),
      radial-gradient(circle at 92% 62%, rgba(134, 76, 255, 0.13), transparent 34%),
      linear-gradient(135deg, #05070e 0%, #071426 45%, #141536 100%);
    color: rgba(247, 250, 255, 0.96);
  }

  .hero-section::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    background:
      linear-gradient(90deg, rgba(147, 197, 253, 0.06) 1px, transparent 1px),
      linear-gradient(180deg, rgba(147, 197, 253, 0.045) 1px, transparent 1px);
    background-size: 76px 76px;
    mask-image: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.72) 42%, transparent 94%);
    opacity: 0.72;
    transform: perspective(720px) rotateX(58deg) translateY(84px) scale(1.26);
    transform-origin: center bottom;
  }

  .hero-section::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.18) 0.55px, transparent 0.55px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 38%);
    background-size: 3px 3px, 100% 100%;
    opacity: 0.16;
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.94fr) minmax(420px, 0.82fr);
    gap: 64px;
    align-items: center;
  }

  .hero-copy {
    max-width: 760px;
  }

  .hero-identity {
    margin-bottom: 30px;
  }

  .hero-name {
    margin: 0;
    color: rgba(248, 251, 255, 0.95);
    font-size: 28px;
    font-weight: 680;
    line-height: 1.18;
  }

  .hero-role {
    margin: 9px 0 0;
    color: rgba(166, 190, 224, 0.62);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 520;
    line-height: 1.4;
  }

  .hero-title {
    margin: 0;
    font-size: 70px;
    font-weight: 760;
    letter-spacing: 0;
    line-height: 1.04;
  }

  .hero-title span {
    display: block;
  }

  .hero-keyword {
    width: fit-content;
    background: linear-gradient(90deg, #c7f7ff 0%, #8fb8ff 48%, #a98cff 100%);
    background-clip: text;
    color: transparent;
    text-shadow: 0 0 28px rgba(116, 182, 255, 0.24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    max-width: 680px;
    margin: 26px 0 0;
    color: rgba(219, 231, 249, 0.72);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .hero-cta {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(178, 207, 255, 0.18);
    border-radius: var(--radius-card);
    padding: 0 16px;
    background: rgba(255, 255, 255, 0.045);
    color: rgba(241, 247, 255, 0.88);
    font-size: 0.9rem;
    font-weight: 650;
    transition:
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      background 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
    backdrop-filter: blur(12px);
  }

  .hero-cta-primary {
    border-color: rgba(185, 224, 255, 0.26);
    background: rgba(185, 224, 255, 0.1);
    box-shadow: 0 0 28px rgba(102, 173, 255, 0.1);
  }

  .hero-cta-secondary {
    color: rgba(207, 219, 240, 0.74);
  }

  .hero-cta:hover {
    transform: translateY(-1px);
    border-color: rgba(193, 226, 255, 0.36);
    background: rgba(255, 255, 255, 0.075);
  }

  .hero-cta:focus-visible {
    outline-color: #bfeeff;
  }

  .method-sample-section {
    background:
      linear-gradient(180deg, rgba(250, 250, 250, 0) 0%, #f3f5f6 18%, #f3f5f6 100%);
  }

  .method-sample-heading {
    max-width: 880px;
    margin-bottom: 34px;
  }

  .method-sample-heading h2 {
    margin: 12px 0 0;
    color: var(--color-text-primary);
    font-size: 2rem;
    font-weight: 680;
    line-height: 1.22;
  }

  .method-sample-heading p:not(.eyebrow) {
    max-width: 800px;
    margin: 14px 0 0;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.8;
  }

  .method-sample-card {
    display: grid;
    overflow: hidden;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.78fr);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
  }

  .method-sample-card__main,
  .method-sample-proof {
    padding: 36px;
  }

  .method-sample-stage {
    width: fit-content;
    margin: 0 0 22px;
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-card);
    padding: 8px 11px;
    background: var(--color-accent-soft);
    color: var(--color-accent-strong);
    font-size: 0.82rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .method-sample-card h3 {
    max-width: 720px;
    margin: 0;
    color: var(--color-text-primary);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.18;
  }

  .method-sample-blocks {
    margin-top: 30px;
  }

  .method-sample-block {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: 22px;
  }

  .method-sample-block:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .method-sample-block:last-child {
    padding-bottom: 0;
  }

  .method-sample-label {
    margin: 0 0 10px;
    color: var(--color-text-primary);
    font-size: 0.96rem;
    font-weight: 700;
  }

  .method-sample-block p:not(.method-sample-label) {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.98rem;
    line-height: 1.82;
  }

  .method-workflow {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 18px;
  }

  .method-workflow__step {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: var(--radius-card);
    padding: 0 10px;
    background: #f8fafb;
    color: var(--color-text-primary);
    font-size: 0.85rem;
    font-weight: 620;
  }

  .method-workflow__index {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .method-sample-proof {
    border-left: 1px solid var(--color-border-subtle);
    background:
      linear-gradient(180deg, rgba(15, 107, 131, 0.06), rgba(15, 107, 131, 0)),
      #fbfcfd;
  }

  .method-sample-proof h4 {
    margin: 14px 0 0;
    color: var(--color-text-primary);
    font-size: 1.28rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .method-sample-proof ul {
    display: grid;
    gap: 14px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .method-sample-proof li {
    position: relative;
    padding-left: 18px;
    color: var(--color-text-secondary);
    font-size: 0.94rem;
    line-height: 1.68;
  }

  .method-sample-proof li::before {
    position: absolute;
    top: 0.75em;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-accent);
    content: "";
    transform: translateY(-50%);
  }

  .method-sample-link {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    margin-top: 30px;
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-card);
    padding: 0 15px;
    background: var(--color-text-primary);
    color: var(--color-text-inverse);
    font-size: 0.9rem;
    font-weight: 680;
    transition:
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      background 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .method-sample-link:hover {
    transform: translateY(-1px);
    background: var(--color-accent-strong);
  }

  @media (max-width: 980px) {
    .hero-section {
      min-height: auto;
      padding-block: 72px 76px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 46px;
    }

    .hero-title {
      font-size: 58px;
    }

    .method-sample-card {
      grid-template-columns: 1fr;
    }

    .method-sample-proof {
      border-top: 1px solid var(--color-border-subtle);
      border-left: 0;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-block: 58px 64px;
    }

    .hero-identity {
      margin-bottom: 22px;
    }

    .hero-name {
      font-size: 25px;
    }

    .hero-role {
      font-size: 0.72rem;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.72;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-cta {
      width: 100%;
    }

    .method-sample-heading h2,
    .method-sample-card h3 {
      font-size: 1.62rem;
    }

    .method-sample-card__main,
    .method-sample-proof {
      padding: 24px;
    }

    .method-sample-stage {
      width: 100%;
    }

    .method-workflow {
      display: grid;
      grid-template-columns: 1fr;
    }

    .method-workflow__step {
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta,
    .method-sample-link {
      transition: none;
    }

    .hero-cta:hover,
    .method-sample-link:hover {
      transform: none;
    }
  }
</style>
