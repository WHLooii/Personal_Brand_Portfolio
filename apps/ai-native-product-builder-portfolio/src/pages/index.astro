---
import AIPMCapabilitySystem from "@/components/AIPMCapabilitySystem.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroAbilitySystem from "@/components/HeroAbilitySystem.astro";
import ProductOperatingProcess from "@/components/ProductOperatingProcess.astro";
import { getProjectSlug, getProjects } from "@/lib/content";

const projects = await getProjects();
const methodSampleProject = projects.find((project) => getProjectSlug(project) === "ecommerce-review-copilot");
const methodSampleHref = methodSampleProject
  ? `/projects/${getProjectSlug(methodSampleProject)}/`
  : "/projects/ecommerce-review-copilot/";

const methodWorkflow = ["评论输入", "主题聚类", "差评归因", "风险提示", "建议卡片", "人工复盘", "指标评估"];

const methodCapabilities = [
  "能从模糊业务需求中拆出真实问题",
  "能判断 AI 适合做什么、不适合做什么",
  "能设计 Human-in-the-loop 的人机协作闭环",
  "能把产品判断落成可演示、可测试的 MVP",
  "能为 AI 输出设计评估指标，而不是只停留在“看起来能用”"
];
---

<BaseLayout
  title="巫浩林 | AI Product Builder"
  description="巫浩林的 AI Product Builder 个人品牌首页，展示 AI 产品判断、Workflow 设计、MVP 原型构建与评估迭代能力。"
  headerVariant="dark"
>
  <section class="hero-section">
    <div class="site-shell hero-grid">
      <div class="hero-copy">
        <h1 class="hero-name">巫浩林</h1>
        <div class="hero-position" aria-label="职业定位">
          <span>AI Product Manager</span>
          <span>AI 产品原型构建者</span>
        </div>
        <p class="hero-statement">
          <span>把业务问题</span>
          <span>转化为</span>
          <span class="hero-statement__accent">可验证的 AI 产品</span>
        </p>
        <p class="hero-subtitle">
          我关注的不是“做了多少项目”，而是如何发现值得 AI 化的产品机会，设计可控的 AI Workflow，并用 MVP 快速验证。
        </p>
        <div class="hero-actions" aria-label="首页主要操作">
          <a class="hero-cta hero-cta-primary" href="#capabilities">查看能力系统</a>
          <a class="hero-cta hero-cta-secondary" href="#method-sample">查看方法样本</a>
        </div>
      </div>
      <HeroAbilitySystem />
    </div>
  </section>

  <AIPMCapabilitySystem />

  <ProductOperatingProcess />

  <section id="method-sample" class="method-sample-section">
    <div class="site-shell">
      <div class="method-sample-heading">
        <h2>一个样本，展示完整 AIPM 判断链路</h2>
      </div>

      <article class="method-sample-card">
        <div class="method-sample-card__main">
          <p class="method-sample-stage">
            当前验证阶段：V0.1 方法样本，重点验证产品判断链路、交互闭环与评估方法。
          </p>
          <p class="method-sample-system-label">Problem Framing</p>
          <h3>找到 AI 真正应该解决的问题</h3>
          <p class="method-sample-subtitle">样本 01：从非结构化评论到运营决策</p>

          <div class="method-sample-blocks">
            <div class="method-sample-block">
              <p class="method-sample-label">问题</p>
              <p>
                评论数据量大、表达口语化、归因不稳定，运营团队难以从大量用户评论中快速判断问题优先级。
              </p>
            </div>
            <div class="method-sample-block">
              <p class="method-sample-label">我的判断</p>
              <p>
                这个场景不适合一开始就做“自动运营 Agent”。更合理的切入点是先做一个可复核的评论洞察 Copilot，让 AI 帮助运营人员完成主题聚类、差评归因、风险提示和建议生成，但最终决策仍由人确认。
              </p>
            </div>
            <div class="method-sample-block">
              <p class="method-sample-label">原型方向</p>
              <p>
                先把评论洞察流程落成可演示、可复核的 MVP，让每一步输出都能被人工确认，并能进入后续指标评估。
              </p>
              <div class="method-workflow" aria-label="评论洞察 Copilot 原型方向">
                {
                  methodWorkflow.map((step, index) => (
                    <span class="method-workflow__step">
                      <span class="method-workflow__index">{String(index + 1).padStart(2, "0")}</span>
                      <span>{step}</span>
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <aside class="method-sample-proof" aria-label="样本能力证明">
          <p class="eyebrow">能力证明</p>
          <h4>这个样本证明什么能力</h4>
          <ul>
            {methodCapabilities.map((capability) => <li>{capability}</li>)}
          </ul>
          <a class="method-sample-link" href={methodSampleHref}>查看拆解过程</a>
        </aside>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    box-sizing: border-box;
    overflow: hidden;
    min-height: 100svh;
    height: 100svh;
    display: grid;
    align-items: center;
    padding-block: 24px;
    background:
      linear-gradient(180deg, transparent 66%, var(--color-night-800) 100%),
      radial-gradient(circle at 76% 32%, rgba(91, 140, 255, 0.2), transparent 29%),
      radial-gradient(circle at 92% 62%, rgba(139, 92, 246, 0.14), transparent 34%),
      var(--gradient-night-hero);
    color: var(--color-text-on-dark-primary);
  }

  .hero-section::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    background:
      linear-gradient(90deg, rgba(147, 197, 253, 0.06) 1px, transparent 1px),
      linear-gradient(180deg, rgba(147, 197, 253, 0.045) 1px, transparent 1px);
    background-size: 76px 76px;
    mask-image: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.72) 42%, transparent 94%);
    opacity: 0.72;
    transform: perspective(720px) rotateX(58deg) translateY(84px) scale(1.26);
    transform-origin: center bottom;
  }

  .hero-section::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.18) 0.55px, transparent 0.55px),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 38%);
    background-size: 3px 3px, 100% 100%;
    opacity: 0.14;
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(420px, 0.92fr);
    gap: 72px;
    align-items: center;
    transform: translateY(clamp(18px, 2.6svh, 30px));
  }

  .hero-copy {
    max-width: 760px;
  }

  .hero-name {
    margin: 0;
    color: var(--color-text-on-dark-primary);
    font-size: 4rem;
    font-weight: 760;
    line-height: 1;
  }

  .hero-position {
    display: grid;
    gap: 6px;
    margin-top: 18px;
    color: rgba(191, 238, 255, 0.86);
    font-size: 1.375rem;
    font-weight: 620;
    line-height: 1.25;
  }

  .hero-position span:last-child {
    color: var(--color-text-on-dark-muted);
    font-size: 0.72em;
    font-weight: 560;
  }

  .hero-statement {
    max-width: 720px;
    margin: 34px 0 0;
    color: rgba(245, 247, 250, 0.94);
    font-size: 3.25rem;
    font-weight: 720;
    line-height: 1.03;
  }

  .hero-statement span {
    display: block;
    width: fit-content;
  }

  .hero-statement__accent {
    background: linear-gradient(90deg, #c7f7ff 0%, #8fb8ff 48%, #a98cff 100%);
    background-clip: text;
    color: transparent;
    text-shadow: 0 0 28px rgba(116, 182, 255, 0.24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    max-width: 600px;
    margin: 22px 0 0;
    color: var(--color-text-on-dark-secondary);
    font-size: 1.02rem;
    line-height: 1.86;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .hero-cta {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(178, 207, 255, 0.18);
    border-radius: var(--radius-control);
    padding: 0 16px;
    background: var(--surface-glass);
    color: rgba(241, 247, 255, 0.88);
    font-size: 0.9rem;
    font-weight: 650;
    transition:
      transform var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      background var(--duration-fast) var(--ease-standard);
    backdrop-filter: blur(12px);
  }

  .hero-cta-primary {
    border-color: rgba(185, 224, 255, 0.26);
    background: rgba(185, 224, 255, 0.1);
    box-shadow: 0 0 28px rgba(102, 173, 255, 0.1);
  }

  .hero-cta-secondary {
    color: rgba(207, 219, 240, 0.74);
  }

  .hero-cta:hover {
    transform: translateY(-1px);
    border-color: rgba(193, 226, 255, 0.36);
    background: rgba(255, 255, 255, 0.075);
  }

  .hero-cta:focus-visible {
    outline-color: var(--color-accent-on-dark);
  }

  .method-sample-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: 136px 164px;
    background:
      var(--texture-mist-dither),
      radial-gradient(circle at 78% 24%, rgba(126, 167, 221, 0.18), transparent 32%),
      radial-gradient(circle at 18% 48%, rgba(191, 238, 255, 0.1), transparent 34%),
      linear-gradient(
        180deg,
        #263247 0%,
        #344156 16%,
        var(--color-mist-700) 34%,
        #7f899b 50%,
        var(--color-mist-400) 64%,
        #d7dce5 82%,
        var(--color-porcelain) 100%
      );
    background-blend-mode: soft-light, normal, normal, normal;
    background-size: 128px 128px, auto, auto, auto;
    color: var(--color-text-on-dark-primary);
  }

  .method-sample-section > .site-shell {
    position: relative;
    z-index: 1;
  }

  .method-sample-section::before {
    content: none;
  }

  .method-sample-section::after {
    position: absolute;
    left: 50%;
    bottom: -132px;
    z-index: 0;
    width: min(920px, 86vw);
    height: 330px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.54);
    content: "";
    filter: blur(70px);
    pointer-events: none;
    transform: translateX(-50%);
  }

  .method-sample-heading {
    max-width: 980px;
    margin-bottom: 34px;
  }

  .method-sample-heading h2 {
    max-width: 980px;
    margin: 0;
    color: #f5f7fa;
    font-size: 2.75rem;
    font-weight: 740;
    line-height: 1.14;
  }

  .method-sample-proof .eyebrow {
    color: var(--color-accent-on-dark);
  }

  .method-sample-card {
    position: relative;
    display: grid;
    overflow: hidden;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.78fr);
    border: 1px solid var(--color-border-cool-subtle);
    border-radius: var(--radius-shell);
    background: var(--color-paper);
    box-shadow: var(--shadow-paper-shell);
    backdrop-filter: blur(22px);
  }

  .method-sample-card::after {
    position: absolute;
    inset-inline: 12%;
    bottom: -34px;
    height: 72px;
    content: "";
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.6), transparent 68%);
    pointer-events: none;
  }

  .method-sample-card__main,
  .method-sample-proof {
    position: relative;
    z-index: 1;
    padding: 44px;
  }

  .method-sample-stage {
    width: fit-content;
    margin: 0 0 22px;
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-control);
    padding: 8px 11px;
    background: var(--color-accent-soft);
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    font-weight: 650;
    line-height: 1.5;
  }

  .method-sample-system-label {
    margin: 0 0 16px;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 700;
    line-height: 1.45;
    text-transform: uppercase;
  }

  .method-sample-card h3 {
    max-width: 620px;
    margin: 0;
    color: var(--color-text-primary);
    font-size: 2.45rem;
    font-weight: 720;
    line-height: 1.12;
  }

  .method-sample-subtitle {
    max-width: 560px;
    margin: 14px 0 0;
    color: var(--color-text-secondary);
    font-size: 1.08rem;
    font-weight: 600;
    line-height: 1.62;
  }

  .method-sample-blocks {
    margin-top: 34px;
  }

  .method-sample-block {
    border-top: 1px solid var(--color-border-cool-subtle);
    padding-block: 22px;
  }

  .method-sample-block:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .method-sample-block:last-child {
    padding-bottom: 0;
  }

  .method-sample-label {
    margin: 0 0 10px;
    color: var(--color-text-primary);
    font-size: 0.96rem;
    font-weight: 700;
  }

  .method-sample-block p:not(.method-sample-label) {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.98rem;
    line-height: 1.86;
  }

  .method-workflow {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 18px;
  }

  .method-workflow__step {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-control);
    padding: 0 10px;
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 620;
  }

  .method-workflow__index {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .method-sample-proof {
    border-left: 1px solid rgba(191, 219, 254, 0.16);
    background:
      radial-gradient(circle at 86% 10%, rgba(191, 238, 255, 0.12), transparent 30%),
      linear-gradient(160deg, #253149 0%, #172238 58%, #10182a 100%);
  }

  .method-sample-proof h4 {
    margin: 14px 0 0;
    color: var(--color-text-on-dark-primary);
    font-size: 1.28rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .method-sample-proof ul {
    display: grid;
    gap: 14px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .method-sample-proof li {
    position: relative;
    padding-left: 18px;
    color: var(--color-text-on-dark-secondary);
    font-size: 0.94rem;
    line-height: 1.76;
  }

  .method-sample-proof li::before {
    position: absolute;
    top: 0.75em;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #8fb8ff;
    content: "";
    transform: translateY(-50%);
  }

  .method-sample-link {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    margin-top: 30px;
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-control);
    padding: 0 15px;
    background: #f3f6fb;
    color: #0b1020;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.18),
      0 16px 44px rgba(180, 200, 255, 0.18);
    transition:
      transform var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      background var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard);
  }

  .method-sample-link:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.88);
    background: #ffffff;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.22),
      0 22px 60px rgba(190, 210, 255, 0.26);
  }

  @media (max-width: 980px) {
    .hero-section {
      height: auto;
      min-height: auto;
      padding-block: 132px 76px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 46px;
      transform: none;
    }

    .method-sample-card {
      grid-template-columns: 1fr;
    }

    .method-sample-proof {
      border-top: 1px solid rgba(191, 219, 254, 0.16);
      border-left: 0;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-block: 132px 64px;
    }

    .hero-name {
      font-size: 3.35rem;
    }

    .hero-statement {
      font-size: 2.52rem;
      line-height: 1.05;
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.72;
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-cta {
      width: 100%;
    }

    .method-sample-section {
      padding-block: 76px;
    }

    .method-sample-heading h2 {
      font-size: 1.95rem;
    }

    .method-sample-card h3 {
      font-size: 1.62rem;
    }

    .method-sample-card__main,
    .method-sample-proof {
      padding: 24px;
    }

    .method-sample-stage {
      width: 100%;
    }

    .method-workflow {
      display: grid;
      grid-template-columns: 1fr;
    }

    .method-workflow__step {
      justify-content: flex-start;
    }

  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cta,
    .method-sample-link {
      transition: none;
    }

    .hero-cta:hover,
    .method-sample-link:hover {
      transform: none;
    }
  }
</style>
